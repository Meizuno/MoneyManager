generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NUXT_DATABASE_URL")
}

model Transaction {
  id         Int      @id @default(autoincrement())
  date       DateTime
  name       String
  amount     Decimal
  currency   String?
  type       String   @default("other")
  category   String   @default("other")
  user_id    String
  created_at DateTime @default(now())

  @@index([date])
  @@index([type])
  @@index([category])
  @@index([user_id])
  @@map("transactions")
}

model SalesSplit {
  id         Int      @id @default(autoincrement())
  user_id    String   @unique
  rules      Json     @default("[]")
  updated_at DateTime @updatedAt

  @@map("sales_splits")
}
