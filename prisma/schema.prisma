generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NUXT_DATABASE_URL")
}

model Transaction {
  id         Int      @id @default(autoincrement())
  date       DateTime
  name       String
  amount     Decimal
  currency   String?
  type       String   @default("other")
  category   String   @default("other")
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())

  @@index([date])
  @@index([type])
  @@index([category])
  @@index([user_id])
  @@map("transactions")
}

model User {
  id           String        @id
  email        String?
  name         String?
  picture      String?
  created_at   DateTime      @default(now())
  tokens       RefreshToken[]
  transactions Transaction[]
  sales_split  SalesSplit?

  @@map("users")
}

model SalesSplit {
  id         Int      @id @default(autoincrement())
  user_id    String   @unique
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  rules      Json     @default("[]")
  updated_at DateTime @updatedAt

  @@map("sales_splits")
}

model RefreshToken {
  id         String   @id
  user_id    String
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_tokens")
}
