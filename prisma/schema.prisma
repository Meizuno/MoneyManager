generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NUXT_DATABASE_URL")
}

model Income {
  id         Int      @id @default(autoincrement())
  date       DateTime
  name       String
  amount     Decimal  @db.Decimal(10, 2)
  currency   String?
  category   Int      @default(0)
  user_id    String
  created_at DateTime @default(now())

  @@index([date])
  @@index([category])
  @@index([user_id])
  @@map("incomes")
}

model Expense {
  id         Int      @id @default(autoincrement())
  date       DateTime
  name       String
  amount     Decimal  @db.Decimal(10, 2)
  currency   String?
  category   Int      @default(0)
  user_id    String
  created_at DateTime @default(now())

  @@index([date])
  @@index([category])
  @@index([user_id])
  @@map("expenses")
}

model ExpenseCategory {
  id         Int      @id @default(autoincrement())
  user_id    String
  label      String
  percent    Decimal  @db.Decimal(5, 2)
  color      String
  position   Int      @default(0)
  created_at DateTime @default(now())

  @@index([user_id])
  @@map("expense_categories")
}

model IncomeCategory {
  id         Int      @id @default(autoincrement())
  user_id    String
  label      String
  color      String
  position   Int      @default(0)
  created_at DateTime @default(now())

  @@index([user_id])
  @@map("income_categories")
}

// Scoped personal access tokens. Only the sha256 hash of the token is
// stored — the raw `mm_pat_…` value is shown to the user once at
// creation and never persisted. `scopes` holds the granted scope
// strings ('read' | 'add'); a JWT/session principal is full-access and
// has no row here.
model PersonalAccessToken {
  id           String    @id @default(cuid())
  user_id      String
  name         String
  token_hash   String    @unique
  scopes       String[]  @default([])
  created_at   DateTime  @default(now())
  last_used_at DateTime?
  expires_at   DateTime?
  revoked_at   DateTime?

  @@index([user_id])
  @@map("personal_access_tokens")
}
