generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NUXT_DATABASE_URL")
}

model Income {
  id         Int      @id @default(autoincrement())
  date       DateTime
  name       String
  amount     Decimal  @db.Decimal(10, 2)
  currency   String?
  category   Int      @default(0)
  user_id    String
  created_at DateTime @default(now())

  @@index([date])
  @@index([category])
  @@index([user_id])
  @@map("incomes")
}

model Expense {
  id         Int      @id @default(autoincrement())
  date       DateTime
  name       String
  amount     Decimal  @db.Decimal(10, 2)
  currency   String?
  category   Int      @default(0)
  user_id    String
  created_at DateTime @default(now())

  @@index([date])
  @@index([category])
  @@index([user_id])
  @@map("expenses")
}

model ExpenseCategory {
  id         Int      @id @default(autoincrement())
  user_id    String
  label      String
  percent    Decimal  @db.Decimal(5, 2)
  color      String
  position   Int      @default(0)
  created_at DateTime @default(now())

  @@index([user_id])
  @@map("expense_categories")
}

model IncomeCategory {
  id         Int      @id @default(autoincrement())
  user_id    String
  label      String
  color      String
  position   Int      @default(0)
  created_at DateTime @default(now())

  @@index([user_id])
  @@map("income_categories")
}
