generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("NUXT_DATABASE_URL")
}

model Transaction {
  id         Int      @id @default(autoincrement())
  date       DateTime
  name       String
  amount     Decimal
  currency   String?
  type       String   @default("other")
  category   String   @default("other")
  user_id    String
  created_at DateTime @default(now())

  @@index([date])
  @@index([type])
  @@index([category])
  @@index([user_id])
  @@map("transactions")
}

model SalesSplitRule {
  id         Int      @id @default(autoincrement())
  user_id    String
  label      String
  percent    Decimal
  color      String
  position   Int      @default(0)
  created_at DateTime @default(now())

  @@index([user_id])
  @@map("sales_split_rules")
}

model IncomeCategoryRule {
  id         Int      @id @default(autoincrement())
  user_id    String
  label      String
  color      String
  position   Int      @default(0)
  created_at DateTime @default(now())

  @@index([user_id])
  @@map("income_category_rules")
}
